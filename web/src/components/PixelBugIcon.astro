  <rect x="8" y="14" width="4" height="4" rx="1" fill="currentColor" />
  <rect x="20" y="14" width="4" height="4" rx="1" fill="currentColor" />
  <rect x="13" y="18" width="2" height="4" rx="1" fill="currentColor" />
