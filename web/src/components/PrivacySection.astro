---
import Container from './Container.astro';
---

<section class="py-[var(--space-section)]">
  <Container>
    <div class="rounded-2xl border border-slate-800 bg-slate-900/60 p-8">
      <h2 class="text-3xl font-semibold">Safety & privacy by design</h2>
      <p class="mt-3 max-w-3xl text-slate-300">
        Perbug uses your location only to rank nearby plans by relevance and timeliness. We never publish your exact location, and you can turn permissions off anytime from settings.
      </p>
      <div class="mt-6 grid gap-4 sm:grid-cols-3">
        <div class="rounded-xl border border-slate-800 bg-slate-950/70 p-4">
          <p class="font-semibold">Permission-based</p>
          <p class="mt-2 text-sm text-slate-400">You stay in control of location access.</p>
        </div>
        <div class="rounded-xl border border-slate-800 bg-slate-950/70 p-4">
          <p class="font-semibold">No location selling</p>
          <p class="mt-2 text-sm text-slate-400">Data is not sold to third-party ad networks.</p>
        </div>
        <div class="rounded-xl border border-slate-800 bg-slate-950/70 p-4">
          <p class="font-semibold">Transparent sources</p>
          <p class="mt-2 text-sm text-slate-400">Results blend Perbug signals with trusted provider data.</p>
        </div>
      </div>
    </div>
  </Container>
</section>
