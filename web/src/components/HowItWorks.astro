---
import Container from './Container.astro';

const steps = [
  {
    title: 'Discover',
    description: 'Explore nearby places with smart ranking that adapts to your mood, timing, and distance.'
  },
  {
    title: 'Save',
    description: 'Build lists for date nights, quick lunches, coffee runs, and weekend plans.'
  },
  {
    title: 'Review',
    description: 'Leave trusted ratings with photos and videos so others see what it is really like.'
  },
  {
    title: 'Share',
    description: 'Send top picks to friends instantly and decide faster without opening five apps.'
  },
  {
    title: 'Follow creators',
    description: 'Find local voices with consistent taste and follow their guides, spots, and updates.'
  },
  {
    title: 'Plan outings',
    description: 'Use the AI planner to map a full outing in one flow.'
  }
];
---

<section id="how-it-works" class="py-[var(--space-section)]">
  <Container>
    <h2 class="text-3xl font-semibold">How Perbug works</h2>
    <p class="mt-3 max-w-3xl text-slate-300">From first idea to final plan in minutes. Perbug turns local discovery into a clean, social, creator-friendly experience.</p>
    <div class="mt-8 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
      {steps.map((step, idx) => (
        <article class="rounded-2xl border border-slate-800 bg-slate-900/60 p-6">
          <p class="text-sm font-semibold text-neon-purple">Step {idx + 1}</p>
          <h3 class="mt-2 text-xl font-semibold">{step.title}</h3>
          <p class="mt-3 text-slate-300">{step.description}</p>
        </article>
      ))}
    </div>
  </Container>
</section>
