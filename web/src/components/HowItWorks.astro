---
import Container from './Container.astro';

const steps = [
  {
    title: 'Pick your vibe',
    description: 'Choose categories like coffee, food, bars, and activities so Perbug understands your mood.'
  },
  {
    title: 'Swipe yes / no / maybe',
    description: 'Quickly decide what looks good now, then let Perbug rank what best fits your group or solo plan.'
  },
  {
    title: 'Go with live confidence',
    description: 'See what is hot nearby right now, save winning plans, and share with friends instantly.'
  }
];
---

<section id="how-it-works" class="py-[var(--space-section)]">
  <Container>
    <h2 class="text-3xl font-semibold">How Perbug works</h2>
    <p class="mt-3 max-w-2xl text-slate-300">Built for right-now decisions, not endless tabs. From filters to final choice in under a minute.</p>
    <div class="mt-8 grid gap-4 md:grid-cols-3">
      {steps.map((step, idx) => (
        <article class="rounded-2xl border border-slate-800 bg-slate-900/60 p-6">
          <p class="text-sm font-semibold text-neon-purple">Step {idx + 1}</p>
          <h3 class="mt-2 text-xl font-semibold">{step.title}</h3>
          <p class="mt-3 text-slate-300">{step.description}</p>
        </article>
      ))}
    </div>
  </Container>
</section>
