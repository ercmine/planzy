---
import Container from './Container.astro';

const features = [
  { title: 'Smarter local discovery', desc: 'Find better places faster with ranking tuned to context, quality, and live local momentum.' },
  { title: 'Rich place detail pages', desc: 'See menus, hours, vibe, accessibility context, and what to expect before you arrive.' },
  { title: 'Photo + video reviews', desc: 'Go beyond text reviews with visual proof from people who were actually there.' },
  { title: 'Creator guides & collections', desc: 'Browse curated lists from trusted creators and save them directly to your plans.' },
  { title: 'Saved places and lists', desc: 'Organize favorites by moment, neighborhood, or budget and keep plans ready to go.' },
  { title: 'AI outing planner', desc: 'Generate a full route for meals, activities, and stops with one planning flow.' },
  { title: 'Trusted review system', desc: 'Quality-focused moderation and reputation signals help surface reviews worth trusting.' },
  { title: 'Social following feed', desc: 'Follow creators and friends to keep up with fresh local recommendations.' }
];
---

<section id="features" class="py-[var(--space-section)]">
  <Container>
    <div class="mb-8 flex flex-wrap items-end justify-between gap-4">
      <div>
        <h2 class="text-3xl font-semibold">Built for free discovery and creator sharing</h2>
        <p class="mt-2 max-w-3xl text-slate-300">Perbug combines recommendations, social trust, and creator tools in one modern local platform.</p>
      </div>
      <a href="/demo/" class="text-sm font-semibold text-brand-400 hover:text-brand-300">See product preview →</a>
    </div>
    <div class="grid gap-4 md:grid-cols-2">
      {features.map((feature) => (
        <article class="rounded-2xl border border-slate-800 bg-slate-900/60 p-6">
          <h3 class="text-lg font-semibold">{feature.title}</h3>
          <p class="mt-2 text-slate-300">{feature.desc}</p>
        </article>
      ))}
    </div>
  </Container>
</section>
