---
import Container from './Container.astro';
import PixelBugIcon from './PixelBugIcon.astro';
import { publicConfig } from '@/env/public';
---

<footer class="mt-20 border-t border-slate-800 py-10">
  <Container class="grid gap-6 text-sm text-slate-400 md:grid-cols-3">
    <div>
      <div class="flex items-center gap-2 text-brand-400">
        <PixelBugIcon class="h-5 w-5" />
        <p class="font-semibold text-slate-100">Perbug</p>
      </div>
      <p class="mt-3 max-w-xs">Plans that match your moment. Live nearby ideas for coffee, food, bars, and activities.</p>
    </div>
    <div>
      <p class="font-semibold text-slate-200">Links</p>
      <div class="mt-3 grid gap-2">
        <a href="/downloads/" class="hover:text-brand-400">Get the App</a>
        <a href="/demo/" class="hover:text-brand-400">Try the Demo</a>
        <a href="/privacy/" class="hover:text-brand-400">Privacy</a>
        <a href="/terms/" class="hover:text-brand-400">Terms</a>
      </div>
    </div>
    <div>
      <p class="font-semibold text-slate-200">Contact</p>
      <div class="mt-3 grid gap-2">
        {publicConfig.PERBUG_SUPPORT_EMAIL && (
          <a href={`mailto:${publicConfig.PERBUG_SUPPORT_EMAIL}`} class="hover:text-brand-400">{publicConfig.PERBUG_SUPPORT_EMAIL}</a>
        )}
        <a href="https://x.com" class="hover:text-brand-400">X / Twitter</a>
        <a href="https://instagram.com" class="hover:text-brand-400">Instagram</a>
      </div>
    </div>
  </Container>
  <Container class="mt-8 border-t border-slate-800 pt-6 text-xs text-slate-500">© {new Date().getFullYear()} Perbug. All rights reserved.</Container>
</footer>
