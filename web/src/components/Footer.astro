---
import Container from './Container.astro';
import PixelBugIcon from './PixelBugIcon.astro';
import { publicConfig } from '@/env/public';
---

<footer class="mt-20 border-t border-slate-800 py-10">
  <Container class="grid gap-8 text-sm text-slate-400 md:grid-cols-4">
    <div>
      <div class="flex items-center gap-2 text-brand-400">
        <PixelBugIcon class="h-5 w-5" src="/perbug1.svg" alt="Perbug logo" />
        <p class="font-semibold text-slate-100">Perbug</p>
      </div>
      <p class="mt-3 max-w-xs">A smarter local discovery platform for users, creators, and businesses.</p>
    </div>
    <div>
      <p class="font-semibold text-slate-200">Product</p>
      <div class="mt-3 grid gap-2">
        <a href="/downloads/" class="hover:text-brand-400">Get the App</a>
        <a href="/demo/" class="hover:text-brand-400">Product Preview</a>
        <a href="/planner/" class="hover:text-brand-400">Outing Planner</a>
        <a href="#premium" class="hover:text-brand-400">Premium</a>
      </div>
    </div>
    <div>
      <p class="font-semibold text-slate-200">Creators & Businesses</p>
      <div class="mt-3 grid gap-2">
        <a href="#creators" class="hover:text-brand-400">Creator onboarding</a>
        <a href="#business" class="hover:text-brand-400">Business tools</a>
        <a href="/support/" class="hover:text-brand-400">Contact growth team</a>
      </div>
    </div>
    <div>
      <p class="font-semibold text-slate-200">Company</p>
      <div class="mt-3 grid gap-2">
        <a href="/privacy/" class="hover:text-brand-400">Privacy</a>
        <a href="/terms/" class="hover:text-brand-400">Terms</a>
        <a href="/support/" class="hover:text-brand-400">Support</a>
        {publicConfig.PERBUG_SUPPORT_EMAIL && (
          <a href={`mailto:${publicConfig.PERBUG_SUPPORT_EMAIL}`} class="hover:text-brand-400">{publicConfig.PERBUG_SUPPORT_EMAIL}</a>
        )}
      </div>
    </div>
  </Container>
  <Container class="mt-8 border-t border-slate-800 pt-6 text-xs text-slate-500">© {new Date().getFullYear()} Perbug. All rights reserved.</Container>
</footer>
