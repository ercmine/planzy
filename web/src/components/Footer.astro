---
import Container from './Container.astro';
import PixelBugIcon from './PixelBugIcon.astro';
---

<footer class="mt-20 border-t border-slate-800 py-10">
  <Container class="grid gap-8 text-sm text-slate-400 md:grid-cols-4">
    <div>
      <div class="flex items-center gap-2 text-brand-400">
        <PixelBugIcon class="h-5 w-5" src="/perbug1.svg" alt="Perbug logo" />
        <p class="font-semibold text-slate-100">Perbug</p>
      </div>
      <p class="mt-3 max-w-xs">Perbug is a SHA-256 coin and exploration ecosystem powered by Proof of Exploration.</p>
    </div>
    <div>
      <p class="font-semibold text-slate-200">Explore</p>
      <div class="mt-3 grid gap-2">
        <a href="/about/" class="hover:text-brand-400">About Perbug</a>
        <a href="/proof-of-exploration/" class="hover:text-brand-400">Proof of Exploration</a>
        <a href="/roadmap/" class="hover:text-brand-400">Roadmap</a>
        <a href="/faq/" class="hover:text-brand-400">FAQ</a>
      </div>
    </div>
    <div>
      <p class="font-semibold text-slate-200">Developers</p>
      <div class="mt-3 grid gap-2">
        <a href="/developers/" class="hover:text-brand-400">Developer hub</a>
        <a href="https://github.com/perbugcore/" target="_blank" rel="noreferrer" class="hover:text-brand-400">GitHub Organization</a>
        <a href="https://github.com/perbugcore/" target="_blank" rel="noreferrer" class="hover:text-brand-400">Follow development</a>
        <a href="https://t.me/Perbugcore" target="_blank" rel="noreferrer" class="hover:text-brand-400">Telegram</a>
      </div>
    </div>
    <div>
      <p class="font-semibold text-slate-200">Project</p>
      <div class="mt-3 grid gap-2">
        <a href="/#sha-256" class="hover:text-brand-400">SHA-256 Coin</a>
        <a href="/#how-it-works" class="hover:text-brand-400">How It Works</a>
        <a href="/#ecosystem" class="hover:text-brand-400">Ecosystem</a>
      </div>
    </div>
  </Container>
  <Container class="mt-8 border-t border-slate-800 pt-6 text-xs text-slate-500">© {new Date().getFullYear()} Perbug. Open ecosystem, open development.</Container>
</footer>
