---
import Container from './Container.astro';

const credibility = ['Free for everyone', 'Photo + video reviews', 'Creator guides', 'AI planner', 'Ad-supported discovery'];
const socialProof = [
  { label: 'Active local guides', value: '4,200+' },
  { label: 'Cities in rollout', value: '18' },
  { label: 'Weekly place saves', value: '150k+' }
];
---

<section class="bg-hero-glow py-16 sm:py-20">
  <Container class="grid items-center gap-10 lg:grid-cols-2">
    <div class="space-y-6">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-brand-400">Free creator-first local discovery</p>
      <h1 class="text-4xl font-bold tracking-tight sm:text-5xl">Discover where to go next with reviews you can trust.</h1>
      <p class="max-w-xl text-lg text-slate-300">
        Perbug helps you find great places faster with community and creator reviews, visual proof, and social recommendations. Post your own reviews and guides from day one—no subscription required.
      </p>
      <div class="flex flex-wrap gap-3">
        <a href="/downloads/" class="rounded-lg bg-brand-500 px-5 py-3 font-semibold text-slate-950 shadow-soft hover:bg-brand-400">Start Exploring</a>
        <a href="/demo/" class="rounded-lg border border-slate-600 px-5 py-3 font-semibold text-slate-100 hover:border-neon-purple">View Product Preview</a>
      </div>
      <div class="flex flex-wrap gap-4 text-sm">
        <a href="#creators" class="font-semibold text-brand-300 hover:text-brand-200">Create your profile →</a>
      </div>
      <div class="grid gap-3 sm:grid-cols-3">
        {socialProof.map((stat) => (
          <div class="rounded-xl border border-slate-800 bg-slate-900/60 p-3">
            <p class="text-xl font-semibold text-brand-400">{stat.value}</p>
            <p class="text-xs text-slate-400">{stat.label}</p>
          </div>
        ))}
      </div>
    </div>
    <div class="rounded-3xl border border-slate-700 bg-slate-900/70 p-4 shadow-glow">
      <div class="mx-auto max-w-sm rounded-3xl border border-slate-700 bg-slate-950 p-5">
        <p class="text-sm font-semibold text-brand-300">Tonight near you</p>
        <div class="mt-4 space-y-3">
          <div class="rounded-2xl border border-slate-800 bg-slate-900 p-3">
            <p class="text-xs text-slate-400">Trending now • 0.4 mi</p>
            <p class="font-semibold">Moonshot Coffee</p>
            <p class="text-xs text-slate-300">Creator tip: Try the orange cardamom latte before 7pm.</p>
          </div>
          <div class="rounded-2xl border border-slate-800 bg-slate-900 p-3">
            <p class="text-xs text-slate-400">Smart match • 0.9 mi</p>
            <p class="font-semibold">Nori Alley</p>
            <p class="text-xs text-slate-300">92% match for date-night + budget under $40.</p>
          </div>
        </div>
        <div class="mt-4 grid grid-cols-2 gap-2 text-xs font-semibold">
          {credibility.map((item) => <p class="rounded-lg border border-slate-800 bg-slate-900/80 px-2 py-2 text-center text-slate-300">{item}</p>)}
        </div>
      </div>
    </div>
  </Container>
</section>
