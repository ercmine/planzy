---
import Container from './Container.astro';

const audienceCards = [
  {
    id: 'users',
    title: 'For users',
    points: ['Discover better places nearby in real time.', 'Save spots and build local lists.', 'Plan nights out with smarter recommendations.'],
    cta: { label: 'Open the app', href: '/downloads/' }
  },
  {
    id: 'creators',
    title: 'For creators',
    points: ['Publish review videos and visual guides.', 'Grow followers around your local expertise.', 'Unlock premium creator features as Dryad expands.'],
    cta: { label: 'Join as creator', href: '/support/' }
  },
  {
    id: 'business',
    title: 'For businesses',
    points: ['Claim and optimize your place profile.', 'Respond to reviews and collaborate with creators.', 'Track engagement with clear performance analytics.'],
    cta: { label: 'Claim your business', href: '/support/' }
  }
];
---

<section id="audiences" class="py-[var(--space-section)]">
  <Container>
    <h2 class="text-3xl font-semibold">Built for every side of local discovery</h2>
    <p class="mt-3 max-w-2xl text-slate-300">Dryad connects the people exploring, the creators shaping decisions, and the businesses delivering great experiences.</p>
    <div class="mt-8 grid gap-4 lg:grid-cols-3">
      {audienceCards.map((card) => (
        <article id={card.id} class="rounded-2xl border border-slate-800 bg-slate-900/70 p-6">
          <h3 class="text-xl font-semibold">{card.title}</h3>
          <ul class="mt-4 space-y-2 text-slate-300">
            {card.points.map((point) => <li>• {point}</li>)}
          </ul>
          <a href={card.cta.href} class="mt-6 inline-block text-sm font-semibold text-brand-300 hover:text-brand-200">{card.cta.label} →</a>
        </article>
      ))}
    </div>
  </Container>
</section>
