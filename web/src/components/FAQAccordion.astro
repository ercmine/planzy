---
import Container from './Container.astro';

const faqs = [
  {
    q: 'What is Perbug?',
    a: 'Perbug is a location-based plans app that helps you find the best nearby coffee, food, bars, and activities happening right now.'
  },
  {
    q: 'Does it require location?',
    a: 'Perbug works best with location enabled so it can rank nearby options. You can still browse, and permissions can be changed anytime.'
  },
  {
    q: 'Is it free?',
    a: 'Yes. Perbug is free to use with optional premium features planned as the product expands.'
  },
  {
    q: 'Where does data come from?',
    a: 'Perbug combines app activity signals with provider-style data sources (including future Google Places/Yelp integrations) to keep results fresh.'
  },
  {
    q: 'When is iOS/Android launch?',
    a: 'Perbug is actively rolling out. Join via Get the App to receive the newest iOS and Android availability updates.'
  }
];
---

<section id="faq" class="py-[var(--space-section)]">
  <Container>
    <h2 class="text-3xl font-semibold">FAQ</h2>
    <div class="mt-6 space-y-3">
      {faqs.map((faq) => (
        <details class="rounded-xl border border-slate-800 bg-slate-900/60 p-5">
          <summary class="cursor-pointer list-none text-base font-semibold text-slate-100">{faq.q}</summary>
          <p class="mt-3 text-slate-300">{faq.a}</p>
        </details>
      ))}
    </div>
  </Container>
</section>
