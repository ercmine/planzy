---
import Container from './Container.astro';

const faqs = [
  {
    q: 'What is Dryad?',
    a: 'Dryad is a local discovery platform for finding places, reading trusted reviews, and following creators who publish useful local guides.'
  },
  {
    q: 'Can I use Dryad as a creator?',
    a: 'Yes. Creators can publish review videos, build collections, grow followers, and unlock advanced tools as the creator program expands.'
  },
  {
    q: 'How does Dryad help businesses?',
    a: 'Businesses can claim their profiles, manage content, respond to reviews, understand engagement, and collaborate with local creators.'
  },
  {
    q: 'Is Dryad free?',
    a: 'Core discovery and review features are free, with premium enhancements available for deeper personalization and advanced workflows.'
  },
  {
    q: 'When is Dryad launching in more cities?',
    a: 'Dryad is rolling out in phases. Join through Get the App or Support to receive launch updates for your region.'
  }
];
---

<section id="faq" class="py-[var(--space-section)]">
  <Container>
    <h2 class="text-3xl font-semibold">FAQ</h2>
    <div class="mt-6 space-y-3">
      {faqs.map((faq) => (
        <details class="rounded-xl border border-slate-800 bg-slate-900/60 p-5">
          <summary class="cursor-pointer list-none text-base font-semibold text-slate-100">{faq.q}</summary>
          <p class="mt-3 text-slate-300">{faq.a}</p>
        </details>
      ))}
    </div>
  </Container>
</section>
