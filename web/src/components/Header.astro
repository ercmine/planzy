---
import Container from './Container.astro';
import PixelBugIcon from './PixelBugIcon.astro';

const links = [
  { href: '/#what-is-perbug', label: 'What is Perbug' },
  { href: '/#sha-256', label: 'SHA-256 Coin' },
  { href: '/#proof-of-exploration', label: 'Proof of Exploration' },
  { href: '/#how-it-works', label: 'How It Works' },
  { href: '/developers/', label: 'Developers' },
  { href: '/roadmap/', label: 'Roadmap' },
  { href: '/faq/', label: 'FAQ' }
];
---

<header class="sticky top-0 z-20 border-b border-slate-800/80 bg-slate-950/85 backdrop-blur">
  <Container class="py-3">
    <div class="flex min-h-12 items-center justify-between gap-4">
      <a href="/" class="flex items-center gap-2 text-brand-400">
        <PixelBugIcon class="h-6 w-6" src="/perbug1.svg" alt="Perbug logo" />
        <span class="text-base font-semibold tracking-wide text-slate-100">Perbug</span>
      </a>
      <div class="flex items-center gap-2">
        <a href="https://app.perbug.com" target="_blank" rel="noreferrer" class="rounded-lg bg-brand-500 px-4 py-2 text-sm font-semibold text-slate-950 hover:bg-brand-400">
          Open Web App
        </a>
        <a href="https://github.com/perbugcore/" target="_blank" rel="noreferrer" class="rounded-lg border border-slate-600 px-4 py-2 text-sm font-semibold text-slate-100 hover:border-brand-300">
          View GitHub
        </a>
        <a href="https://t.me/Perbugcore" target="_blank" rel="noreferrer" class="rounded-lg border border-slate-600 px-4 py-2 text-sm font-semibold text-slate-100 hover:border-brand-300">
          Join Telegram
        </a>
      </div>
    </div>
    <nav class="mt-3 flex flex-wrap gap-x-5 gap-y-2 text-sm text-slate-300 sm:mt-2 sm:justify-end">
      {links.map((link) => <a href={link.href} class="hover:text-brand-400">{link.label}</a>)}
    </nav>
  </Container>
</header>
