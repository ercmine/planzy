---
import Container from './Container.astro';
import PixelBugIcon from './PixelBugIcon.astro';

const links = [
  { href: '#how-it-works', label: 'How it works' },
  { href: '#features', label: 'Features' },
  { href: '#audiences', label: 'For everyone' },
  { href: '#premium', label: 'Premium' },
  { href: '#faq', label: 'FAQ' }
];
---

<header class="sticky top-0 z-20 border-b border-slate-800/80 bg-slate-950/85 backdrop-blur">
  <Container class="py-3">
    <div class="flex min-h-12 items-center justify-between gap-4">
      <a href="/" class="flex items-center gap-2 text-brand-400">
        <PixelBugIcon class="h-6 w-6" />
        <span class="text-base font-semibold tracking-wide text-slate-100">Perbug</span>
      </a>
      <a href="/downloads/" class="rounded-lg bg-brand-500 px-4 py-2 text-sm font-semibold text-slate-950 hover:bg-brand-400">
        Get the App
      </a>
    </div>
    <nav class="mt-3 flex flex-wrap gap-x-5 gap-y-2 text-sm text-slate-300 sm:mt-2 sm:justify-end">
      {links.map((link) => <a href={link.href} class="hover:text-brand-400">{link.label}</a>)}
    </nav>
  </Container>
</header>
