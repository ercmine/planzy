---
import Container from './Container.astro';

const features = [
  {
    title: 'Session Workflows',
    description: 'Create and run structured planning sessions with clear steps for every participant.'
  },
  {
    title: 'Realtime Alignment',
    description: 'Keep everyone focused with synchronized session states and decision checkpoints.'
  },
  {
    title: 'Telemetry Insights',
    description: 'Measure engagement and outcomes with privacy-conscious analytics controls.'
  },
  {
    title: 'Developer-friendly APIs',
    description: 'Integrate Dryad with your systems using simple, documented endpoints.'
  }
];
---

<section class="pb-8">
  <Container>
    <div class="mb-8 flex items-end justify-between gap-4">
      <h2 class="text-2xl font-semibold">Core features</h2>
      <a href="/docs/" class="text-sm font-semibold text-brand-600 hover:text-brand-700">Read the docs →</a>
    </div>
    <div class="grid gap-4 sm:grid-cols-2">
      {
        features.map((feature) => (
          <article class="rounded-2xl border border-slate-200 bg-white p-6 dark:border-slate-800 dark:bg-slate-900">
            <h3 class="mb-2 text-lg font-semibold">{feature.title}</h3>
            <p class="text-slate-600 dark:text-slate-300">{feature.description}</p>
          </article>
        ))
      }
    </div>
  </Container>
</section>
