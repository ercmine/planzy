---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/Container.astro';
import { createSeo } from '@/lib/seo';

const seo = createSeo({
  title: 'Proof of Exploration',
  description: 'Understand Proof of Exploration, Perbug\'s mechanism for linking real-world activity and blockchain participation.',
  path: '/proof-of-exploration/'
});
---

<BaseLayout {...seo}>
  <Container class="py-16">
    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-brand-300">Mechanism</p>
    <h1 class="mt-3 text-4xl font-bold text-white">Proof of Exploration</h1>
    <p class="mt-5 max-w-3xl text-slate-300">
      Proof of Exploration is Perbug\'s core participation model. Users discover locations and interact with the world through map-based gameplay.
      These actions connect to ecosystem opportunities and chain-relevant outcomes.
    </p>
    <ul class="mt-6 grid gap-3 text-slate-300 md:grid-cols-2">
      <li class="rounded-xl border border-slate-800 bg-slate-900/60 p-4">Exploration-first user journeys</li>
      <li class="rounded-xl border border-slate-800 bg-slate-900/60 p-4">Gameplay with location context</li>
      <li class="rounded-xl border border-slate-800 bg-slate-900/60 p-4">Rewards and claims tied to participation</li>
      <li class="rounded-xl border border-slate-800 bg-slate-900/60 p-4">Open-source evolution on GitHub</li>
    </ul>
  </Container>
</BaseLayout>
