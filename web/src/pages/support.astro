---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/Container.astro';
import { publicConfig } from '@/env/public';
import { createSeo } from '@/lib/seo';

const seo = createSeo({
  title: 'Support',
  description: 'Contact Dryad support and find help resources.',
  path: '/support/'
});
---

<BaseLayout {...seo}>
  <Container class="py-20">
    <h1 class="text-4xl font-bold">Support</h1>
    <p class="mt-3 text-slate-600 dark:text-slate-300">Need help with sessions, account access, or integrations? We are here to help.</p>
    <div class="mt-8 grid gap-4 sm:grid-cols-2">
      <article class="rounded-2xl border border-slate-200 bg-white p-6 dark:border-slate-800 dark:bg-slate-900">
        <h2 class="text-lg font-semibold">Email</h2>
        {publicConfig.DRYAD_SUPPORT_EMAIL ? (
          <a class="mt-2 block text-brand-600 hover:text-brand-700" href={`mailto:${publicConfig.DRYAD_SUPPORT_EMAIL}`}>
            {publicConfig.DRYAD_SUPPORT_EMAIL}
          </a>
        ) : (
          <p class="mt-2 text-slate-600 dark:text-slate-300">Support email coming soon.</p>
        )}
      </article>
      <article class="rounded-2xl border border-slate-200 bg-white p-6 dark:border-slate-800 dark:bg-slate-900">
        <h2 class="text-lg font-semibold">Self-service resources</h2>
        <ul class="mt-3 space-y-2 text-sm">
          <li><a class="text-brand-600 hover:text-brand-700" href="/docs/getting-started/">Getting Started Guide</a></li>
          <li><a class="text-brand-600 hover:text-brand-700" href="/docs/faq/">Frequently Asked Questions</a></li>
          <li><a class="text-brand-600 hover:text-brand-700" href="/privacy/">Privacy Policy</a></li>
        </ul>
      </article>
    </div>
  </Container>
</BaseLayout>
