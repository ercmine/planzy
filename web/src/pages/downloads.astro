---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/Container.astro';
import CTAButtons from '@/components/CTAButtons.astro';
import { createSeo } from '@/lib/seo';
import { publicConfig } from '@/env/public';

const seo = createSeo({
  title: 'Downloads',
  description: 'Download Perbug on iOS and Android.',
  path: '/downloads/'
});

const links = [
  { platform: 'App Store', href: publicConfig.PERBUG_APPSTORE_URL },
  { platform: 'Google Play', href: publicConfig.PERBUG_PLAYSTORE_URL }
];
---

<BaseLayout {...seo}>
  <Container class="py-20">
    <h1 class="text-4xl font-bold">Download Perbug</h1>
    <p class="mt-3 text-slate-600 dark:text-slate-300">Get the app from your preferred store. Missing links will appear as coming soon.</p>
    <div class="mt-8">
      <CTAButtons />
    </div>
    <div class="mt-10 grid gap-4 sm:grid-cols-2">
      {links.map((link) => (
        <div class="rounded-2xl border border-slate-200 bg-white p-6 dark:border-slate-800 dark:bg-slate-900">
          <h2 class="text-lg font-semibold">{link.platform}</h2>
          <p class="mt-2 text-sm text-slate-600 dark:text-slate-300">{link.href ? 'Ready to download now.' : 'Coming soon — check back shortly.'}</p>
          <div class="mt-5 flex h-32 items-center justify-center rounded-xl border border-dashed border-slate-300 text-xs text-slate-500 dark:border-slate-700">
            QR placeholder
          </div>
        </div>
      ))}
    </div>
  </Container>
</BaseLayout>
