---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/Container.astro';
import { createSeo } from '@/lib/seo';

const seo = createSeo({
  title: 'FAQ',
  description: 'Perbug FAQ covering the SHA-256 coin, Proof of Exploration, and open-source project links.',
  path: '/faq/'
});

const faqs = [
  ['Is Perbug a coin or a game?', 'Perbug is both: a SHA-256 coin plus an exploration-driven ecosystem.'],
  ['Where is the code?', 'The primary open-source hub is https://github.com/perbugcore/.'],
  ['Who is Perbug for?', 'Perbug is for users, crypto-native communities, and developers interested in exploration-linked systems.']
];
---

<BaseLayout {...seo}>
  <Container class="py-16">
    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-brand-300">FAQ</p>
    <h1 class="mt-3 text-4xl font-bold text-white">Frequently asked questions</h1>
    <div class="mt-6 space-y-3">
      {faqs.map(([q, a]) => (
        <details class="rounded-xl border border-slate-800 bg-slate-900/60 p-5">
          <summary class="cursor-pointer text-lg font-semibold text-white">{q}</summary>
          <p class="mt-2 text-slate-300">{a}</p>
        </details>
      ))}
    </div>
  </Container>
</BaseLayout>
