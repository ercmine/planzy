---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero.astro';
import FeatureGrid from '@/components/FeatureGrid.astro';
import Container from '@/components/Container.astro';
import { createSeo, defaultDescription } from '@/lib/seo';

const seo = createSeo({ title: 'Home', description: defaultDescription, path: '/' });
---

<BaseLayout {...seo}>
  <Hero />
  <FeatureGrid />
  <Container class="py-16">
    <div class="rounded-2xl border border-slate-200 bg-white p-8 text-center dark:border-slate-800 dark:bg-slate-900">
      <h2 class="text-2xl font-semibold">Explore Perbug</h2>
      <p class="mt-3 text-slate-600 dark:text-slate-300">
        Learn how Perbug works, review our legal pages, or get support from our team.
      </p>
      <div class="mt-5 flex flex-wrap justify-center gap-3 text-sm font-semibold">
        <a class="rounded-lg border border-slate-300 px-4 py-2 hover:border-brand-500" href="/docs/">Docs</a>
        <a class="rounded-lg border border-slate-300 px-4 py-2 hover:border-brand-500" href="/privacy/">Privacy</a>
        <a class="rounded-lg border border-slate-300 px-4 py-2 hover:border-brand-500" href="/terms/">Terms</a>
        <a class="rounded-lg border border-slate-300 px-4 py-2 hover:border-brand-500" href="/support/">Support</a>
      </div>
    </div>
  </Container>
</BaseLayout>
