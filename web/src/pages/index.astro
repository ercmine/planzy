---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero.astro';
import HowItWorks from '@/components/HowItWorks.astro';
import FeatureCards from '@/components/FeatureCards.astro';
import LiveResultsPreview from '@/components/LiveResultsPreview.astro';
import FAQAccordion from '@/components/FAQAccordion.astro';
import Container from '@/components/Container.astro';
import { createSeo } from '@/lib/seo';

const pageDescription =
  'Dryad is a free creator-first local discovery app where anyone can browse places, post reviews and videos, build guides, and follow creators.';

const seo = createSeo({
  title: 'Free local discovery and creator reviews for everyone',
  description: pageDescription,
  path: '/'
});

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What is Dryad?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Dryad is a free local discovery platform where people discover places, trust creator and community reviews, and plan outings with smart recommendations.'
      }
    },
    {
      '@type': 'Question',
      name: 'Who can create content on Dryad?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Any signed-in user can post text, photo, and video reviews, publish guides, and build a creator profile.'
      }
    },
    {
      '@type': 'Question',
      name: 'Does Dryad have paid plans?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'No. Dryad is free for everyone and supported by ads in discovery.'
      }
    },
    {
      '@type': 'Question',
      name: 'How are ads shown?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Dryad uses an ad-supported discovery model with sponsored cards shown in-feed at a consistent cadence.'
      }
    }
  ]
};

const credibilityPills = ['Free for everyone', 'Creator content', 'Trusted reviews', 'AI planner', 'Ad-supported discovery'];
---

<BaseLayout {...seo} structuredData={faqSchema}>
  <Hero />

  <Container class="pb-4">
    <div class="flex flex-wrap gap-3 rounded-2xl border border-slate-800 bg-slate-900/60 p-4 text-sm text-slate-300">
      {credibilityPills.map((pill) => <p class="rounded-full border border-slate-700 px-3 py-1">{pill}</p>)}
    </div>
  </Container>

  <HowItWorks />
  <FeatureCards />
  <LiveResultsPreview />

  <Container class="pb-8">
    <section class="rounded-3xl border border-slate-800 bg-slate-900/70 p-5 md:p-8">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-brand-300">Sponsored</p>
      <div class="mt-4 grid gap-5 md:grid-cols-[1.2fr_1fr] md:items-center">
        <div>
          <h2 class="text-2xl font-semibold text-slate-50 md:text-3xl">See Dryad in action</h2>
          <p class="mt-3 text-slate-300">
            Watch our latest app ad to preview creator videos, trusted reviews, and smart local planning in one place.
          </p>
          <a
            href="/downloads/"
            class="mt-5 inline-flex rounded-lg bg-brand-500 px-4 py-2 font-semibold text-slate-950 transition hover:bg-brand-400"
          >
            Download Dryad
          </a>
        </div>

        <video
          class="w-full rounded-2xl border border-slate-700 bg-slate-950 shadow-lg"
          src="/dryad.mp4"
          controls
          preload="metadata"
          muted
          playsinline
          aria-label="Dryad app ad video"
        >
          Sorry, your browser does not support embedded videos.
        </video>
      </div>
    </section>
  </Container>

  <FAQAccordion />

  <Container class="pb-16 text-center">
    <h2 class="text-3xl font-semibold">Ready to explore and share your local favorites?</h2>
    <p class="mx-auto mt-3 max-w-2xl text-slate-300">Start discovering places, follow creators, and post your own reviews and guides for free.</p>
    <div class="mt-6 flex flex-wrap justify-center gap-3">
      <a href="/downloads/" class="rounded-lg bg-brand-500 px-5 py-3 font-semibold text-slate-950 hover:bg-brand-400">Start exploring</a>
      <a href="#creators" class="rounded-lg border border-slate-600 px-5 py-3 font-semibold text-slate-100 hover:border-neon-purple">Create your profile</a>
    </div>
  </Container>
</BaseLayout>
