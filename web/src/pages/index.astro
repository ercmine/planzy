---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero.astro';
import HowItWorks from '@/components/HowItWorks.astro';
import FeatureCards from '@/components/FeatureCards.astro';
import LiveResultsPreview from '@/components/LiveResultsPreview.astro';
import FAQAccordion from '@/components/FAQAccordion.astro';
import Container from '@/components/Container.astro';
import { createSeo } from '@/lib/seo';

const pageDescription =
  'Perbug is a smart local discovery platform for users, creators, and businesses—trusted reviews, creator content, and AI-powered outing planning in one app.';

const seo = createSeo({
  title: 'Smarter local discovery for users, creators, and businesses',
  description: pageDescription,
  path: '/'
});

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What is Perbug?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Perbug is a local discovery platform where people discover places, trust creator and community reviews, and plan outings with smart recommendations.'
      }
    },
    {
      '@type': 'Question',
      name: 'Who is Perbug built for?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Perbug supports everyday users, creators who publish local review content, and businesses that manage their profiles and customer engagement.'
      }
    },
    {
      '@type': 'Question',
      name: 'Does Perbug support creators and businesses?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. Creators can publish guides and build followers, while businesses can claim profiles, respond to reviews, and improve visibility.'
      }
    },
    {
      '@type': 'Question',
      name: 'Is there a premium experience?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Perbug includes free core features with premium enhancements for deeper recommendations, cleaner browsing, and advanced tools for creators and businesses.'
      }
    }
  ]
};

const credibilityPills = ['Trusted reviews', 'Local discovery', 'Creator content', 'Smart recommendations', 'Business tools'];
---

<BaseLayout {...seo} structuredData={faqSchema}>
  <Hero />

  <Container class="pb-4">
    <div class="flex flex-wrap gap-3 rounded-2xl border border-slate-800 bg-slate-900/60 p-4 text-sm text-slate-300">
      {credibilityPills.map((pill) => <p class="rounded-full border border-slate-700 px-3 py-1">{pill}</p>)}
    </div>
  </Container>

  <HowItWorks />
  <FeatureCards />
  <LiveResultsPreview />

  <section id="premium" class="py-[var(--space-section)]">
    <Container class="rounded-3xl border border-slate-800 bg-slate-900/60 p-8">
      <h2 class="text-3xl font-semibold">Perbug Premium</h2>
      <p class="mt-3 max-w-3xl text-slate-300">Upgrade for cleaner browsing, sharper recommendations, and extra power for creator and business workflows as Perbug launches city by city.</p>
      <div class="mt-6 grid gap-3 md:grid-cols-2 xl:grid-cols-4">
        <p class="rounded-xl border border-slate-700 p-4">Reduced ads and cleaner discovery flows</p>
        <p class="rounded-xl border border-slate-700 p-4">Smarter personalized recommendations</p>
        <p class="rounded-xl border border-slate-700 p-4">Advanced creator visibility tools</p>
        <p class="rounded-xl border border-slate-700 p-4">Business profile and engagement enhancements</p>
      </div>
      <a href="/support/" class="mt-6 inline-block text-sm font-semibold text-brand-300 hover:text-brand-200">Get premium updates →</a>
    </Container>
  </section>

  <FAQAccordion />

  <Container class="pb-16 text-center">
    <h2 class="text-3xl font-semibold">Ready to launch your Perbug presence?</h2>
    <p class="mx-auto mt-3 max-w-2xl text-slate-300">Start exploring local recommendations, join as a creator, or claim your business profile to connect with more customers.</p>
    <div class="mt-6 flex flex-wrap justify-center gap-3">
      <a href="/downloads/" class="rounded-lg bg-brand-500 px-5 py-3 font-semibold text-slate-950 hover:bg-brand-400">Start exploring</a>
      <a href="#creators" class="rounded-lg border border-slate-600 px-5 py-3 font-semibold text-slate-100 hover:border-neon-purple">Join as creator</a>
      <a href="#business" class="rounded-lg border border-slate-600 px-5 py-3 font-semibold text-slate-100 hover:border-neon-purple">Claim your business</a>
    </div>
  </Container>
</BaseLayout>
