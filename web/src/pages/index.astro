---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero.astro';
import HowItWorks from '@/components/HowItWorks.astro';
import FeatureCards from '@/components/FeatureCards.astro';
import LiveResultsPreview from '@/components/LiveResultsPreview.astro';
import PrivacySection from '@/components/PrivacySection.astro';
import FAQAccordion from '@/components/FAQAccordion.astro';
import Container from '@/components/Container.astro';
import { createSeo } from '@/lib/seo';

const pageDescription =
  'Perbug helps you find the best nearby plans right now with live location-based results, smart category filters, and fast yes/no/maybe decisions.';

const seo = createSeo({
  title: 'Find the best nearby plans right now',
  description: pageDescription,
  path: '/'
});

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What is Perbug?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Perbug is a location-based plans app that helps you find the best nearby coffee, food, bars, and activities happening right now.'
      }
    },
    {
      '@type': 'Question',
      name: 'Does it require location?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Perbug works best with location enabled so it can rank nearby options, and you can change permissions any time.'
      }
    },
    {
      '@type': 'Question',
      name: 'Is it free?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. Perbug is free to use, with optional premium features planned as the platform grows.'
      }
    },
    {
      '@type': 'Question',
      name: 'Where does data come from?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Perbug combines live app signals with provider-style data, including future integrations similar to Google Places and Yelp.'
      }
    },
    {
      '@type': 'Question',
      name: 'When is iOS/Android launch?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Perbug is rolling out in phases. Use Get the App to receive latest launch availability.'
      }
    }
  ]
};
---

<BaseLayout {...seo} structuredData={faqSchema}>
  <Hero />
  <HowItWorks />
  <FeatureCards />
  <LiveResultsPreview />
  <PrivacySection />
  <FAQAccordion />
  <Container class="pb-16 text-center">
    <h2 class="text-3xl font-semibold">Ready to find your next plan?</h2>
    <p class="mt-3 text-slate-300">Download Perbug or try the demo preview to see live, local recommendations in action.</p>
    <div class="mt-6 flex flex-wrap justify-center gap-3">
      <a href="/downloads/" class="rounded-lg bg-brand-500 px-5 py-3 font-semibold text-slate-950 hover:bg-brand-400">Get the App</a>
      <a href="/demo/" class="rounded-lg border border-slate-600 px-5 py-3 font-semibold text-slate-100 hover:border-neon-purple">Try the Demo</a>
    </div>
  </Container>
</BaseLayout>
