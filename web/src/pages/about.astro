---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/Container.astro';
import { createSeo } from '@/lib/seo';

const seo = createSeo({
  title: 'About Perbug',
  description: 'Learn what Perbug is: a SHA-256 coin and exploration ecosystem centered on Proof of Exploration.',
  path: '/about/'
});
---

<BaseLayout {...seo}>
  <Container class="py-16">
    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-brand-300">About Perbug</p>
    <h1 class="mt-3 text-4xl font-bold text-white">Perbug is a SHA-256 coin for an exploration-native ecosystem.</h1>
    <p class="mt-5 max-w-3xl text-slate-300">
      Perbug combines blockchain mechanics with location gameplay. The project introduces Proof of Exploration to connect real-world discovery and participation
      with ecosystem progression.
    </p>
    <a href="https://github.com/perbugcore/" target="_blank" rel="noreferrer" class="mt-8 inline-flex rounded-lg bg-brand-500 px-5 py-3 font-semibold text-slate-950 hover:bg-brand-400">View Perbug GitHub</a>
  </Container>
</BaseLayout>
