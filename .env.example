GOOGLE_MAPS_API_KEY=

# Backend CORS policy
CORS_ALLOWED_ORIGINS=https://app.perbug.com,http://localhost:3000,http://localhost:5173,http://localhost:8080
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,x-user-id,x-request-id,x-acting-profile-type,x-acting-profile-id,x-admin-key
CORS_EXPOSE_HEADERS=x-request-id
CORS_MAX_AGE_SECONDS=600

# Backend -> geo.perbug.com integration
GEO_SERVICE_ENABLED=true
GEO_SERVICE_BASE_URL=https://geo.perbug.com
GEO_SERVICE_TIMEOUT_MS=2000
GEO_SERVICE_RETRIES=1
GEO_SERVICE_AUTH_SECRET=
GEO_SERVICE_FAIL_OPEN=true

# Local Nominatim fallback / geo host defaults
NOMINATIM_BASE_URL=https://geo.perbug.com
NOMINATIM_TIMEOUT_MS=2000
NOMINATIM_GEOCODE_CACHE_TTL_MS=3600000
NOMINATIM_REVERSE_CACHE_TTL_MS=86400000
NOMINATIM_DEFAULT_LIMIT=5
NOMINATIM_ENABLE_FALLBACK=false
NOMINATIM_FALLBACK_BASE_URL=
NOMINATIM_USER_AGENT="perbug-geocoder/1.0 (+https://perbug.com/contact)"
NOMINATIM_RATE_LIMIT_RPS=5
NOMINATIM_CACHE_TTL_SECONDS=3600
NOMINATIM_REVERSE_CACHE_TTL_SECONDS=86400
NOMINATIM_SEARCH_CACHE_TTL_SECONDS=900
GEO_PUBLIC_RATE_LIMIT_PER_MINUTE=180

# AWS video platform
AWS_REGION=us-east-1
AWS_S3_VIDEO_RAW_BUCKET=
AWS_S3_VIDEO_PROCESSED_BUCKET=
AWS_CLOUDFRONT_MEDIA_BASE_URL=
VIDEO_UPLOAD_URL_TTL_SECONDS=900
VIDEO_MAX_UPLOAD_BYTES=2147483648
VIDEO_MULTIPART_THRESHOLD_BYTES=52428800

# PERBUG local node RPC (Bitcoin-style JSON-RPC over localhost only)
PERBUG_RPC_HOST=127.0.0.1
PERBUG_RPC_PORT=9332
PERBUG_RPC_USER=perbugrpc
PERBUG_RPC_PASSWORD=change_this_to_a_long_random_password
PERBUG_NODE_PORT=9333
PERBUG_RPC_TIMEOUT_MS=10000
PERBUG_RPC_WALLET_NAME=
# Legacy aliases still supported: BITCOIN_RPC_HOST/BITCOIN_RPC_PORT/BITCOIN_RPC_USER/BITCOIN_RPC_PASSWORD
PERBUG_PLATFORM_FEE_BPS=500
PERBUG_TIPPING_ENABLED=true
PERBUG_REWARDS_ENABLED=true
PERBUG_ALLOW_SELF_TIP=false
PERBUG_MIN_TIP_ATOMIC=1000000000
PERBUG_MAX_TIP_ATOMIC=100000000000
PERBUG_EXPLORER_BASE_URL=
PERBUG_WALLET_NONCE_TTL_SECONDS=600

# Telegram Mini App bot integration
TELEGRAM_BOT_TOKEN=
PERBUG_MINI_APP_URL=https://app.perbug.com
PERBUG_BOT_DISPLAY_NAME=Perbugbot
